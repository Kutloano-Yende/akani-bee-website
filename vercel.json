{
  "builds": [
    { "src": "*.php", "use": "vercel-php@0.7.2" },
    { "src": "includes/**", "use": "@vercel/static" },
    { "src": "css/**", "use": "@vercel/static" },
    { "src": "js/**", "use": "@vercel/static" },
    { "src": "images/**", "use": "@vercel/static" },
    { "src": "fonts/**", "use": "@vercel/static" },
    { "src": "downloads/**", "use": "@vercel/static" },
    { "src": "favicon.ico", "use": "@vercel/static" },
    { "src": "robots.txt", "use": "@vercel/static" },
    { "src": "sitemap.xml", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/", "dest": "/index.php" },
    { "handle": "filesystem" },
    { "src": "/(.*)\\.php$", "dest": "/$1.php" }
  ]
}
